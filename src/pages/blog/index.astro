---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const allPosts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const categories = [
  { label: '家計管理・節約',    emoji: '💰' },
  { label: '転勤・引越し',      emoji: '📦' },
  { label: '資産形成・つみたて', emoji: '🌱' },
  { label: '暮らしの工夫',      emoji: '🏠' },
  { label: '働き方・キャリア',  emoji: '💼' },
];
---

<!doctype html>
<html lang="ja">
<head>
  <BaseHead title={`記事一覧 | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
</head>
<body>
  <Header />

  <div class="page-wrap wrap">

    <!-- パンくず -->
    <nav class="breadcrumb">
      <a href="/">ホーム</a>
      <span class="sep">›</span>
      <span class="current">記事一覧</span>
    </nav>

    <h1 class="page-title">記事一覧</h1>
    <p class="page-desc">転勤族ママが実践する、お金と暮らしのリアルな記録。全 {allPosts.length} 件</p>

    <div class="content-wrap">

      <!-- MAIN -->
      <main class="main-col">
        <div class="entry-list">
          {allPosts.map((post) => (
            <a href={`/blog/${post.id}/`} class="entry-card">
              <div class="entry-thumb">
                {post.data.heroImage
                  ? <img src={post.data.heroImage} alt={post.data.title} loading="lazy" />
                  : <div class="entry-ph">☕</div>
                }
                {post.data.categories?.[0] &&
                  <span class="entry-cat-label">{post.data.categories[0]}</span>
                }
              </div>
              <div class="entry-body">
                {post.data.categories?.[0] &&
                  <span class="entry-badge">{post.data.categories[0]}</span>
                }
                <h2 class="entry-title">{post.data.title}</h2>
                <p class="entry-excerpt">{post.data.description}</p>
                <p class="entry-date"><FormattedDate date={post.data.pubDate} /></p>
              </div>
            </a>
          ))}
        </div>
      </main>

      <!-- SIDEBAR -->
      <aside class="sidebar">

        <!-- プロフィール -->
        <div class="widget">
          <h3 class="widget-title">✏️ プロフィール</h3>
          <div class="widget-body" style="text-align:center">
            <div class="profile-avatar">
              <img src="/images/IMG_9997-150x150.png" alt="ちょもん" />
            </div>
            <p class="profile-name">ちょもん</p>
            <p class="profile-bio">転勤族のママ。引越し5回の経験から、暮らしとお金の工夫を発信中。</p>
            <a href="/about" class="profile-btn">もっとみる →</a>
          </div>
        </div>

        <!-- カテゴリー -->
        <div class="widget">
          <h3 class="widget-title">📂 カテゴリー</h3>
          <div class="widget-body">
            <ul class="cat-list">
              {categories.map((cat) => (
                <li>
                  <a href="/blog">
                    <span>{cat.emoji}</span>
                    {cat.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </div>

      </aside>
    </div>
  </div>

  <Footer />
</body>
</html>

<style>
.page-wrap { padding-top: 1.5em; padding-bottom: 4em; }

/* パンくず */
.breadcrumb {
  font-size: 0.75em;
  color: var(--text-light);
  margin-bottom: 1.2em;
  display: flex;
  align-items: center;
  gap: 0.4em;
  flex-wrap: wrap;
}
.breadcrumb a { color: var(--accent-dark); }
.breadcrumb a:hover { text-decoration: underline; }
.sep { color: var(--border); }

/* ページタイトル */
.page-title {
  font-size: 1.5em;
  font-family: 'Noto Serif JP', serif;
  color: var(--text-dark);
  margin: 0 0 0.2em;
}
.page-desc {
  font-size: 0.82em;
  color: var(--text-light);
  margin: 0 0 2em;
}

/* レイアウト */
.content-wrap {
  display: grid;
  grid-template-columns: 1fr 280px;
  gap: 2.5em;
  align-items: start;
}

/* 記事カード */
.entry-list { display: flex; flex-direction: column; }

.entry-card {
  display: flex;
  gap: 1em;
  padding: 1.2em 0;
  border-bottom: 1px solid var(--border-light);
  text-decoration: none;
  color: var(--text);
  transition: opacity 0.2s;
  align-items: flex-start;
}
.entry-card:hover { opacity: 0.82; }
.entry-card:first-child { padding-top: 0; }

.entry-thumb {
  flex-shrink: 0;
  width: 160px;
  aspect-ratio: 4/3;
  border-radius: var(--radius);
  overflow: hidden;
  background: var(--bg-warm);
  position: relative;
}
.entry-thumb img {
  width: 100%; height: 100%;
  object-fit: cover;
}
.entry-ph {
  width: 100%; height: 100%;
  display: flex; align-items: center; justify-content: center;
  font-size: 1.8em; color: var(--border);
}
.entry-cat-label {
  position: absolute;
  top: 0.35em; left: 0.35em;
  background: var(--accent);
  color: var(--white);
  font-size: 0.62em;
  padding: 0.2em 0.6em;
  border-radius: var(--radius-pill);
  font-weight: 700;
}

.entry-body { flex: 1; min-width: 0; }
.entry-badge {
  display: inline-block;
  background: var(--accent-pale);
  color: var(--accent-dark);
  font-size: 0.68em;
  padding: 0.15em 0.7em;
  border-radius: var(--radius-pill);
  margin-bottom: 0.4em;
  font-weight: 700;
}
.entry-title {
  font-size: 0.95em;
  font-weight: 700;
  color: var(--text-dark);
  line-height: 1.6;
  margin: 0 0 0.3em;
  font-family: 'Noto Sans JP', sans-serif;
}
.entry-excerpt {
  font-size: 0.78em;
  color: var(--text-light);
  margin: 0 0 0.4em;
  line-height: 1.65;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.entry-date { font-size: 0.72em; color: var(--text-light); margin: 0; }

/* サイドバー */
.sidebar { position: sticky; top: 80px; }

.profile-avatar {
  width: 80px; height: 80px;
  border-radius: 50%;
  overflow: hidden;
  margin: 0 auto 0.6em;
  border: 3px solid var(--accent-light);
}
.profile-avatar img {
  width: 100%; height: 100%; object-fit: cover;
}
.profile-name {
  font-weight: 700;
  font-size: 0.95em;
  color: var(--text-dark);
  margin: 0 0 0.4em;
  font-family: 'Noto Serif JP', serif;
}
.profile-bio {
  font-size: 0.78em;
  color: var(--text-light);
  line-height: 1.75;
  margin: 0 0 0.8em;
  text-align: left;
}
.profile-btn {
  display: inline-block;
  background: var(--accent);
  color: var(--white);
  font-size: 0.78em;
  padding: 0.4em 1.2em;
  border-radius: var(--radius-pill);
  font-weight: 700;
  transition: background 0.2s;
}
.profile-btn:hover { background: var(--accent-dark); color: var(--white); }

.cat-list { list-style: none; padding: 0; margin: 0; }
.cat-list li { border-bottom: 1px solid var(--border-light); }
.cat-list li:last-child { border-bottom: none; }
.cat-list a {
  display: flex;
  align-items: center;
  gap: 0.5em;
  padding: 0.5em 0;
  font-size: 0.85em;
  color: var(--text);
  transition: color 0.2s;
}
.cat-list a:hover { color: var(--accent-dark); }

@media (max-width: 900px) {
  .content-wrap { grid-template-columns: 1fr; }
  .sidebar { position: static; }
}
@media (max-width: 520px) {
  .entry-thumb { width: 110px; }
}
</style>
