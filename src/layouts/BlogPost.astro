---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { getCollection } from 'astro:content';

type Props = CollectionEntry<'blog'>['data'];
const { title, description, pubDate, updatedDate, heroImage, categories } = Astro.props;

const allPosts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const relatedPosts = allPosts.filter(p => p.data.title !== title).slice(0, 3);
const recentPosts  = allPosts.slice(0, 5);
---

<html lang="ja">
<head>
  <BaseHead title={title} description={description} />
</head>
<body>
  <Header />

  <div class="page-wrap wrap">
    <div class="content-wrap">

      <!-- ===== ARTICLE ===== -->
      <main class="main-col">
        <article>

          <!-- パンくず -->
          <nav class="breadcrumb">
            <a href="/">ホーム</a>
            <span class="sep">›</span>
            <a href="/blog">記事一覧</a>
            <span class="sep">›</span>
            <span class="current">{title}</span>
          </nav>

          <!-- カテゴリ・タイトル・メタ -->
          {categories?.[0] &&
            <span class="art-cat">{categories[0]}</span>
          }
          <h1 class="art-title">{title}</h1>
          <div class="art-meta">
            <span class="art-date">📅 <FormattedDate date={pubDate} /></span>
            {updatedDate && (
              <span class="art-updated">🔄 更新: <FormattedDate date={updatedDate} /></span>
            )}
          </div>

          <!-- アイキャッチ -->
          {heroImage && (
            <div class="art-hero">
              <img src={heroImage} alt={title} />
            </div>
          )}

          <!-- リード文（description） -->
          {description && (
            <div class="art-desc">
              <p>{description}</p>
            </div>
          )}

          <!-- 目次（折りたたみ） -->
          <details class="toc-box" open>
            <summary class="toc-summary">
              <span class="toc-icon">📋</span> 目次
            </summary>
            <div class="toc-inner" id="toc-inner">
              <!-- JSで自動生成 -->
            </div>
          </details>

          <!-- 本文 -->
          <div class="prose" id="article-body">
            <slot />
          </div>

          <!-- 関連記事 -->
          {relatedPosts.length > 0 && (
            <section class="related-section">
              <h2 class="related-title">
                <span class="related-icon">📎</span> 関連記事
              </h2>
              <div class="related-grid">
                {relatedPosts.map((post) => (
                  <a href={`/blog/${post.id}/`} class="related-card">
                    <div class="related-thumb">
                      {post.data.heroImage
                        ? <img src={post.data.heroImage} alt={post.data.title} loading="lazy" />
                        : <div class="related-ph">☕</div>
                      }
                    </div>
                    <p class="related-card-title">{post.data.title}</p>
                  </a>
                ))}
              </div>
            </section>
          )}

          <!-- プロフィールボックス -->
          <div class="author-box">
            <div class="author-avatar">
              <img src="/images/IMG_9997-150x150.png" alt="ちょもん" />
            </div>
            <div class="author-body">
              <p class="author-name">この記事を書いた人：ちょもん</p>
              <p class="author-bio">
                30代・2児の母。転勤族のママとして5回の引越しを経験。最初は家計管理が苦手だったけど、今は毎月7.5万円を先取り積立中。転勤族でもできるお金の工夫と暮らしのヒントを発信しています。
              </p>
              <a href="/about" class="author-link">プロフィールを読む →</a>
            </div>
          </div>

          <!-- 戻るボタン -->
          <div class="back-wrap">
            <a href="/blog" class="back-btn">← 記事一覧にもどる</a>
          </div>

        </article>
      </main>

      <!-- ===== SIDEBAR ===== -->
      <aside class="sidebar">

        <!-- プロフィール -->
        <div class="widget">
          <h3 class="widget-title">✏️ プロフィール</h3>
          <div class="widget-body" style="text-align:center">
            <div class="profile-avatar">
              <img src="/images/IMG_9997-150x150.png" alt="ちょもん" />
            </div>
            <p class="profile-name">ちょもん</p>
            <p class="profile-bio">転勤族のママ。引越し5回の経験から、暮らしとお金の工夫を発信中。</p>
            <a href="/about" class="profile-btn">もっとみる →</a>
          </div>
        </div>

        <!-- 新着記事 -->
        <div class="widget">
          <h3 class="widget-title">📝 新着記事</h3>
          <div class="widget-body">
            <ul class="side-posts">
              {recentPosts.map((post) => (
                <li>
                  <a href={`/blog/${post.id}/`} class="side-post">
                    <div class="side-thumb">
                      {post.data.heroImage
                        ? <img src={post.data.heroImage} alt={post.data.title} loading="lazy" />
                        : <div class="side-ph">☕</div>
                      }
                    </div>
                    <div class="side-body">
                      <p class="side-title">{post.data.title}</p>
                      <p class="side-date"><FormattedDate date={post.data.pubDate} /></p>
                    </div>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </div>

        <!-- カテゴリー -->
        <div class="widget">
          <h3 class="widget-title">📂 カテゴリー</h3>
          <div class="widget-body">
            <ul class="cat-list">
              <li><a href="/blog"><span>💰</span> 家計管理・節約</a></li>
              <li><a href="/blog"><span>📦</span> 転勤・引越し</a></li>
              <li><a href="/blog"><span>🌱</span> 資産形成・つみたて</a></li>
              <li><a href="/blog"><span>🏠</span> 暮らしの工夫</a></li>
              <li><a href="/blog"><span>💼</span> 働き方・キャリア</a></li>
            </ul>
          </div>
        </div>

      </aside>
    </div>
  </div>

  <Footer />
</body>
</html>

<!-- 目次自動生成スクリプト -->
<script>
  const body    = document.getElementById('article-body');
  const tocInner = document.getElementById('toc-inner');
  if (body && tocInner) {
    const headings = body.querySelectorAll('h2, h3');
    if (headings.length === 0) {
      // 見出しがなければ目次ボックスごと非表示
      const tocBox = document.querySelector('.toc-box') as HTMLElement | null;
      if (tocBox) tocBox.style.display = 'none';
    } else {
      const ul = document.createElement('ul');
      ul.className = 'toc-list';
      headings.forEach((h, i) => {
        // IDを付与
        const id = `toc-${i}`;
        h.id = id;
        const li = document.createElement('li');
        li.className = h.tagName === 'H3' ? 'toc-h3' : 'toc-h2';
        li.innerHTML = `<a href="#${id}">${h.textContent}</a>`;
        ul.appendChild(li);
      });
      tocInner.appendChild(ul);
    }
  }
</script>

<style>
.page-wrap { padding-top: 1.5em; padding-bottom: 4em; }

.content-wrap {
  display: grid;
  grid-template-columns: 1fr 280px;
  gap: 2.5em;
  align-items: start;
}

/* ===== パンくず ===== */
.breadcrumb {
  font-size: 0.75em;
  color: var(--text-light);
  margin-bottom: 1.2em;
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 0.3em;
}
.breadcrumb a { color: var(--accent-dark); }
.breadcrumb a:hover { text-decoration: underline; }
.sep { color: var(--border); }
.current {
  color: var(--text-light);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 220px;
}

/* ===== 記事ヘッダー ===== */
.art-cat {
  display: inline-block;
  background: var(--accent-pale);
  color: var(--accent-dark);
  font-size: 0.75em;
  padding: 0.25em 0.9em;
  border-radius: var(--radius-pill);
  font-weight: 700;
  margin-bottom: 0.6em;
  border: 1px solid var(--accent-light);
}
.art-title {
  font-size: clamp(1.25em, 3.5vw, 1.75em);
  color: var(--text-dark);
  line-height: 1.55;
  margin-bottom: 0.5em;
  font-family: 'Noto Serif JP', serif;
}
.art-meta {
  font-size: 0.78em;
  color: var(--text-light);
  display: flex;
  gap: 1.2em;
  flex-wrap: wrap;
  margin-bottom: 1.2em;
}
.art-hero {
  margin: 1em 0 1.8em;
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: var(--shadow);
}
.art-hero img {
  width: 100%;
  height: auto;
  display: block;
}
.art-desc {
  background: var(--bg-warm);
  border-left: 4px solid var(--accent-light);
  padding: 0.9em 1.2em;
  border-radius: 0 var(--radius) var(--radius) 0;
  margin-bottom: 1.8em;
  font-size: 0.9em;
  color: var(--text);
  line-height: 1.8;
}
.art-desc p { margin: 0; }

/* ===== 目次 ===== */
.toc-box {
  background: var(--bg-warm);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  margin-bottom: 2em;
  overflow: hidden;
}
.toc-summary {
  cursor: pointer;
  padding: 0.8em 1.2em;
  font-size: 0.88em;
  font-weight: 700;
  color: var(--text-dark);
  display: flex;
  align-items: center;
  gap: 0.4em;
  user-select: none;
  list-style: none;
  border-bottom: 1px solid var(--border);
  background: var(--bg-muted);
}
.toc-summary::-webkit-details-marker { display: none; }
.toc-summary::after {
  content: '▾';
  margin-left: auto;
  font-size: 0.9em;
  color: var(--text-light);
  transition: transform 0.25s;
}
details[open] .toc-summary::after { transform: rotate(180deg); }
.toc-icon { font-size: 1em; }

.toc-inner { padding: 0.8em 1.2em; }
.toc-list {
  list-style: none;
  padding: 0;
  margin: 0;
}
.toc-list .toc-h2 {
  padding: 0.3em 0;
  border-bottom: 1px dotted var(--border-light);
}
.toc-list .toc-h3 {
  padding: 0.25em 0 0.25em 1.2em;
  border-bottom: 1px dotted var(--border-light);
}
.toc-list li:last-child { border-bottom: none; }
.toc-list a {
  font-size: 0.82em;
  color: var(--accent-dark);
  text-decoration: none;
  line-height: 1.5;
  display: block;
}
.toc-list a:hover { text-decoration: underline; }
.toc-list .toc-h2 a::before {
  content: '▸ ';
  color: var(--accent-light);
}
.toc-list .toc-h3 a::before {
  content: '– ';
  color: var(--border);
}

/* ===== 関連記事 ===== */
.related-section {
  margin: 2.5em 0;
  padding: 1.8em;
  background: var(--bg-warm);
  border-radius: var(--radius-lg);
  border: 1px solid var(--border);
}
.related-title {
  font-size: 1em;
  color: var(--text-dark);
  margin: 0 0 1em;
  font-family: 'Noto Sans JP', sans-serif;
  font-weight: 700;
  display: flex;
  align-items: center;
  gap: 0.4em;
}
.related-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 0.8em;
}
.related-card {
  display: block;
  text-decoration: none;
  color: var(--text-dark);
  background: var(--white);
  border-radius: var(--radius);
  overflow: hidden;
  border: 1px solid var(--border);
  transition: transform 0.2s, box-shadow 0.2s;
}
.related-card:hover {
  transform: translateY(-2px);
  box-shadow: var(--shadow-hover);
  color: var(--text-dark);
}
.related-thumb {
  width: 100%;
  aspect-ratio: 16/9;
  overflow: hidden;
  background: var(--bg-muted);
}
.related-thumb img {
  width: 100%; height: 100%;
  object-fit: cover;
}
.related-ph {
  width: 100%; height: 100%;
  display: flex; align-items: center; justify-content: center;
  font-size: 1.5em; color: var(--border);
}
.related-card-title {
  font-size: 0.78em;
  font-weight: 700;
  line-height: 1.5;
  padding: 0.6em 0.7em;
  margin: 0;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* ===== 著者ボックス ===== */
.author-box {
  display: flex;
  gap: 1.2em;
  padding: 1.6em;
  background: var(--bg-warm);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  margin: 2.5em 0 1.5em;
}
.author-avatar {
  flex-shrink: 0;
  width: 80px; height: 80px;
  border-radius: 50%;
  overflow: hidden;
  border: 3px solid var(--white);
  box-shadow: var(--shadow-sm);
}
.author-avatar img {
  width: 100%; height: 100%; object-fit: cover;
}
.author-body { flex: 1; }
.author-name {
  font-size: 0.78em;
  color: var(--text-light);
  font-weight: 700;
  margin: 0 0 0.4em;
  letter-spacing: 0.03em;
}
.author-bio {
  font-size: 0.83em;
  color: var(--text);
  line-height: 1.8;
  margin: 0 0 0.7em;
}
.author-link {
  font-size: 0.8em;
  color: var(--accent-dark);
  font-weight: 700;
  text-decoration: underline;
  text-underline-offset: 3px;
}

/* ===== 戻るボタン ===== */
.back-wrap {
  margin-top: 2em;
  padding-top: 1.2em;
  border-top: 1px dotted var(--border);
}
.back-btn {
  display: inline-block;
  border: 2px solid var(--accent);
  color: var(--accent-dark);
  padding: 0.5em 1.6em;
  border-radius: var(--radius-pill);
  font-size: 0.85em;
  font-weight: 700;
  transition: background 0.25s, color 0.25s;
}
.back-btn:hover {
  background: var(--accent);
  color: var(--white);
}

/* ===== サイドバー ===== */
.sidebar { position: sticky; top: 80px; }

.profile-avatar {
  width: 80px; height: 80px;
  border-radius: 50%;
  overflow: hidden;
  margin: 0 auto 0.6em;
  border: 3px solid var(--accent-light);
}
.profile-avatar img {
  width: 100%; height: 100%; object-fit: cover;
}
.profile-name {
  font-weight: 700;
  font-size: 0.95em;
  color: var(--text-dark);
  margin: 0 0 0.4em;
  font-family: 'Noto Serif JP', serif;
}
.profile-bio {
  font-size: 0.78em;
  color: var(--text-light);
  line-height: 1.75;
  margin: 0 0 0.8em;
  text-align: left;
}
.profile-btn {
  display: inline-block;
  background: var(--accent);
  color: var(--white);
  font-size: 0.78em;
  padding: 0.4em 1.2em;
  border-radius: var(--radius-pill);
  font-weight: 700;
  transition: background 0.2s;
}
.profile-btn:hover { background: var(--accent-dark); color: var(--white); }

.side-posts { list-style: none; padding: 0; margin: 0; }
.side-posts li { border-bottom: 1px solid var(--border-light); }
.side-posts li:last-child { border-bottom: none; }
.side-post {
  display: flex;
  gap: 0.6em;
  padding: 0.6em 0;
  color: var(--text);
  text-decoration: none;
  transition: opacity 0.2s;
}
.side-post:hover { opacity: 0.8; }
.side-thumb {
  flex-shrink: 0;
  width: 60px; aspect-ratio: 1;
  border-radius: var(--radius);
  overflow: hidden;
  background: var(--bg-warm);
}
.side-thumb img { width: 100%; height: 100%; object-fit: cover; }
.side-ph {
  width: 100%; height: 100%;
  display: flex; align-items: center; justify-content: center;
  font-size: 1.1em; color: var(--border);
}
.side-body { flex: 1; min-width: 0; }
.side-title {
  font-size: 0.78em;
  font-weight: 600;
  color: var(--text-dark);
  line-height: 1.5;
  margin: 0 0 0.2em;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.side-date { font-size: 0.68em; color: var(--text-light); margin: 0; }

.cat-list { list-style: none; padding: 0; margin: 0; }
.cat-list li { border-bottom: 1px solid var(--border-light); }
.cat-list li:last-child { border-bottom: none; }
.cat-list a {
  display: flex;
  align-items: center;
  gap: 0.5em;
  padding: 0.5em 0;
  font-size: 0.85em;
  color: var(--text);
  transition: color 0.2s;
}
.cat-list a:hover { color: var(--accent-dark); }

/* ===== レスポンシブ ===== */
@media (max-width: 900px) {
  .content-wrap { grid-template-columns: 1fr; }
  .sidebar { position: static; }
  .related-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 520px) {
  .related-grid { grid-template-columns: 1fr; }
  .author-box { flex-direction: column; }
  .related-section { padding: 1.2em; }
}
</style>
