---
const today = new Date();
---

<footer>
	<p>© {today.getFullYear()} てんままのお金と暮らしブログ. All rights reserved.</p>
	<p class="sub">転勤族ママが実践する、家計管理・節約・老後資金の記録</p>
	<nav class="footer-nav">
		<a href="/privacy-policy">プライバシーポリシー</a>
		<a href="/about">プロフィール</a>
	</nav>
</footer>
<style>
	footer {
		padding: 2em 1em 4em 1em;
		background: linear-gradient(var(--gray-gradient)) no-repeat;
		color: rgb(var(--gray));
		text-align: center;
	}
	footer p {
		margin: 0.3em 0;
	}
	.sub {
		font-size: 0.85em;
		color: rgb(var(--gray));
	}
	.footer-nav {
		margin-top: 1em;
		display: flex;
		justify-content: center;
		gap: 1.5em;
	}
	.footer-nav a {
		color: rgb(var(--gray));
		text-decoration: none;
		font-size: 0.85em;
	}
	.footer-nav a:hover {
		color: rgb(var(--gray-dark));
		text-decoration: underline;
	}
</style>
